# Compose configuration for the local development database (docker-compose.yml).
# Copy to `.env` at the repo root to override the dev defaults. These values are
# for LOCAL development only — never put production secrets here.
#
# The API itself reads its own env from apps/api/.env (see apps/api/.env.example).

POSTGRES_USER=populatte
POSTGRES_PASSWORD=populatte
POSTGRES_DB=populatte

# Host port for the local Postgres (container always listens on 5432).
DB_PORT=5432
