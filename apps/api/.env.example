PORT=3001

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# Extension authentication
EXTENSION_JWT_SECRET=dev_extension_jwt_secret_change_in_production_min_32_chars
EXTENSION_JWT_EXPIRY=30d

# Database
# The app is driven SOLELY by DATABASE_URL — switch environments by changing
# this line only (no code changes). See docs/LOCAL_DB.md.
#
# Local development (Docker Postgres — `npm run db:up` from the repo root):
DATABASE_URL=postgresql://populatte:populatte@localhost:5432/populatte
#
# Production (Supabase pooler — keep commented locally):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
